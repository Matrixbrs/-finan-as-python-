        "    .sum()\n",
        "    .assign(serie_rotulo=\"Total\")\n",
        ")\n",
        "\n",
        "df_concessoes_plot = pd.concat(\n",
        "    [df_concessoes_deflacionado[[\"data\", \"valor_deflacionado\", \"serie_rotulo\"]],\n",
