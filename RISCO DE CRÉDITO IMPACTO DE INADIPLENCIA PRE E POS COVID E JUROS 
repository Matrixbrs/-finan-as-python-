        "    ignore_index=True,\n",
        ")\n",
        "\n",
        "# Gráfico: Volume Mensal Dessazonalizado\n",
        "def dessazonalizar(grupo):\n",
        "    \"\"\"Remove sazonalidade via decomposição aditiva (similar ao X13 simplificado).\"\"\"\n",
        "    grupo = grupo.sort_values(\"data\").set_index(\"data\").asfreq(\"MS\")\n",
        "    serie = grupo[\"valor_deflacionado\"].interpolate()\n",
        "    if len(serie.dropna()) < 24:\n",
        "        grupo[\"valor_dessaz\"] = serie\n",
        "    else:\n",
        "        decomp = seasonal_decompose(serie, model=\"additive\", period=12)\n",
        "        grupo[\"valor_dessaz\"] = decomp.trend + decomp.resid\n",
        "    return grupo.reset_index()\n",
        "\n",
        "df_concessoes_dessaz = (\n",
