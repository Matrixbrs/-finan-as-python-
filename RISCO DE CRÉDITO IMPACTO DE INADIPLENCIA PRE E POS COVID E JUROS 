    {
      "cell_type": "markdown",
      "source": [
        "# RISCO DE CRÉDITO\n",
        "# (dados plotados do BC e IBGE-impacto pré e pós pandemia e juros real)\n"
      ],
      "metadata": {
        "id": "MGCSN7NnCAYV"
      }
    },
    {
      "cell_type": "code",
      "source": [
        "\n",
        "                              #  Dados do Banco Central\n",
        "\n",
        " # Coleta séries do BCB individualmente (com tratamento de erro)\n",
        "dfs_bcb = []\n",
        "series_com_erro = []\n",
        "\n",
        "for nome, codigo in series_bcb.items():\n",
        "    try:\n",
        "        df_temp = sgs.get({nome: codigo}, start=data_inicio, end=data_fim)\n",
        "        df_temp = df_temp.stack().reset_index()\n",
        "        df_temp.columns = [\"data\", \"serie\", \"valor\"]\n",
        "        dfs_bcb.append(df_temp)\n",
        "    except Exception as e:\n",
        "        series_com_erro.append(nome)\n",
        "        print(f\"⚠ Erro ao baixar '{nome}' (código {codigo}): {e}\")\n",
        "\n",
        "if series_com_erro:\n",
        "    print(f\"\\n⚠ Séries não disponíveis: {series_com_erro}\")\n",
        "else:\n",
        "    print(\"✓ Todas as séries BCB baixadas com sucesso.\")\n",
        "\n",
        "df_bcb = pd.concat(dfs_bcb, ignore_index=True)\n",
        "df_bcb[\"data\"] = pd.to_datetime(df_bcb[\"data\"])\n",
        "\n",
        "\n",
        "\n",
        "                             # Dados do IBGE\n",
        "\n",
        " # sidrapy retorna colunas abreviadas: D2C = código da data, V = valor\n",
        "df_desemprego_raw = sidrapy.get_table(\n",
        "    table_code=\"6381\", territorial_level=\"1\", ibge_territorial_code=\"all\",\n",
        "    variable=\"4099\", period=\"all\",\n",
        ")\n",
        "df_rendimento_raw = sidrapy.get_table(\n",
        "    table_code=\"6387\", territorial_level=\"1\", ibge_territorial_code=\"all\",\n",
        "    variable=\"5935\", period=\"all\",\n",
        ")\n",
        "df_ipca_raw = sidrapy.get_table(\n",
        "    table_code=\"1737\", territorial_level=\"1\", ibge_territorial_code=\"all\",\n",
        "    variable=\"2266\", period=\"all\",\n",
        ")\n",
        "\n",
        "# Função de Tratamento dos Dados IBGE\n",
        "def tratar_dados_ibge(df_raw, nome_serie):\n",
        "    \"\"\"Trata dados brutos do SIDRA para formato padronizado.\n",
        "\n",
        "    sidrapy retorna colunas codificadas:\n",
        "      D2C = código da dimensão temporal (YYYYMM)\n",
        "      V   = valor da série\n",
        "    \"\"\"\n",
        "    df = df_raw.copy()\n",
        "# Remove a primeira linha (cabeçalho descritivo do SIDRA)\n",
        "    df = df.iloc[1:]\n",
        "\n",
        "    df = df[[\"D2C\", \"V\"]].rename(columns={\"D2C\": \"data\", \"V\": \"valor\"})\n",
        "\n",
        "# Converte código YYYYMM para datetime\n",
        "    df[\"data\"] = pd.to_datetime(df[\"data\"], format=\"%Y%m\")\n",
        "    df[\"valor\"] = pd.to_numeric(df[\"valor\"], errors=\"coerce\")\n",
        "    df[\"serie\"] = nome_serie\n",
        "\n",
        "    df = df[df[\"data\"] >= pd.to_datetime(data_inicio)].dropna()\n",
        "    return df.reset_index(drop=True)\n",
        "\n",
        "   #  Aplicação do Tratamento\n",
        "df_desemprego = tratar_dados_ibge(df_desemprego_raw, \"desemprego\")\n",
        "df_rendimento = tratar_dados_ibge(df_rendimento_raw, \"rendimento\")\n",
        "df_ipca_indice = tratar_dados_ibge(df_ipca_raw, \"ipca\")\n",
        "\n",
        "      # Consolidação\n",
        "df_full = pd.concat([df_bcb, df_desemprego, df_rendimento], ignore_index=True)\n",
        "\n",
        "print(\"\\n=== Estrutura dos Dados Consolidados ===\")\n",
        "print(f\"Shape: {df_full.shape}\")\n",
        "print(f\"Séries: {df_full['serie'].unique()}\")\n",
        "df_full.head()"
      ],
