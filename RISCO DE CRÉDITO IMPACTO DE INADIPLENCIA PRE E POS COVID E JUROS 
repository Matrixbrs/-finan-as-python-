        "from bcb import sgs\n",
        "\n",
        "# Dados do IBGE/SIDRA (equivalente ao sidrar)\n",
        "import sidrapy\n",
        "\n",
        "# Visualização (equivalente ao ggplot2 + patchwork + scales)\n",
        "import matplotlib.pyplot as plt\n",
        "import matplotlib.ticker as mticker\n",
        "import matplotlib.dates as mdates\n",
        "\n",
        "# Manipulação de dados (equivalente ao dplyr)\n",
        "import pandas as pd\n",
        "import numpy as np\n",
        "\n",
        "# Ajuste sazonal (equivalente ao ggseas)\n",
        "from statsmodels.tsa.seasonal import seasonal_decompose\n",
        "\n",
        "# 1.1 Parâmetros Globais\n",
        "from datetime import date\n",
        "import warnings\n",
        "warnings.filterwarnings(\"ignore\")\n",
        "\n",
        "data_inicio = \"2017-01-01\"\n",
        "data_fim = date.today().strftime(\"%Y-%m-%d\")\n",
        "\n",
        "# Paleta de cores institucional\n",
        "cores_am = [\n",
        "    \"#282f6b\", \"#1B998B\", \"#FF7A00\", \"#00798C\", \"#b22200\", \"#50514F\",\n",
        "    \"#003366\", \"#eace3f\", \"#005A9C\", \"#808080\", \"#2E294E\",\n",
        "]"
