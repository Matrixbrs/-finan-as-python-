      "source": [
        "                                #  DEFINIÇÃO DAS SÉRIES\n",
        "\n",
        "#  Séries do Banco Central (BCB)\n",
        "series_bcb = {\n",
        "    \"inadimplencia_pf_total\": 21084,        # Inadimplência PF Total\n",
        "    \"inadimplencia_pf_livres\": 21112,       # Inadimplência Recursos Livres\n",
        "    \"inadimplencia_pf_dir\": 21145,          # Inadimplência Recursos Direcionados\n",
        "    \"concessoes_livre_pf\": 20662,           # Concessões Recursos Livres\n",
        "    \"concessoes_direcionado_pf\": 20698,     # Concessões Recursos Direcionados\n",
        "    \"endividamento_total\": 29037,           # Endividamento Total (% renda 12m)\n",
        "    \"endividamento_exc_imob\": 29038,        # Endividamento Exceto Imobiliário\n",
        "    \"comprometimento_juros\": 29033,         # Comprometimento com Juros\n",
        "    \"juros_pf_livre\": 20740,               # Taxa Média Recursos Livres\n",
        "    \"selic\": 4189,                          # Taxa Selic\n",
        "}\n",
        "\n",
        "# Séries do IBGE (SIDRA)\n",
        "series_ibge = {\n",
        "    \"rendimento\": \"/t/6387/n1/all/v/5935/p/all\",              # Rendimento Médio Real\n",
        "    \"desemprego\": \"/t/6381/n1/all/v/4099/p/all/d/v4099%201\",  # Taxa de Desocupação\n",
        "    \"ipca\": \"/t/1737/n1/all/v/2266/p/all/d/v2266%2013\",       # IPCA Mensal\n",
        "}\n",
        "\n"
      ],
      "metadata": {
